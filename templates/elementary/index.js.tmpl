// Generated by vst-gen-agent — {{DEVICE_NAME}} Controller (Elementary Audio)
// Sends NRPN messages to the connected hardware device over WebMIDI.

import { WebMidi } from "webmidi";

// ─────────────────────────────────────────────────────────────────────────────
// Parameter map (generated from nrpn_map.json)
// Edit min/max/default values to match your hardware.
// ─────────────────────────────────────────────────────────────────────────────
const PARAMS = [
  // { paramId, label, type, msb, lsb, minVal, maxVal, default }
  // TODO: populated by scaffold.py
];

const MIDI_CHANNEL = {{MIDI_CHANNEL}} - 1; // 0-indexed for WebMIDI
let deviceOut = null;

// ─────────────────────────────────────────────────────────────────────────────
// MIDI helpers
// ─────────────────────────────────────────────────────────────────────────────
function sendNrpn(channel, msb, lsb, value) {
  if (!deviceOut) return;
  const valMsb = (value >> 7) & 0x7f;
  const valLsb = value & 0x7f;
  deviceOut.sendControlChange(99, msb,   { channels: channel + 1 });
  deviceOut.sendControlChange(98, lsb,   { channels: channel + 1 });
  deviceOut.sendControlChange(6,  valMsb, { channels: channel + 1 });
  deviceOut.sendControlChange(38, valLsb, { channels: channel + 1 });
}

function setParam(paramId, value) {
  const p = PARAMS.find((x) => x.paramId === paramId);
  if (!p) return;
  const clamped = Math.max(p.minVal, Math.min(p.maxVal, Math.round(value)));
  if (p.type === "nrpn") {
    sendNrpn(MIDI_CHANNEL, p.msb, p.lsb, clamped);
  } else if (p.type === "cc") {
    deviceOut?.sendControlChange(p.cc, clamped, { channels: MIDI_CHANNEL + 1 });
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// Device connection
// ─────────────────────────────────────────────────────────────────────────────
async function connect() {
  await WebMidi.enable({ sysex: true });
  deviceOut = WebMidi.outputs.find((o) =>
    o.name.toLowerCase().includes("{{CLASS_NAME}}".toLowerCase())
  );
  if (deviceOut) {
    console.log(`✓ Connected to ${deviceOut.name}`);
  } else {
    console.warn("Device not found — check USB connection and MIDI settings.");
    // Retry after 3 s
    setTimeout(connect, 3000);
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// Exports (for use as a module in a host application or DAW bridge)
// ─────────────────────────────────────────────────────────────────────────────
export { PARAMS, setParam, connect };

// ─────────────────────────────────────────────────────────────────────────────
// Standalone entry point
// ─────────────────────────────────────────────────────────────────────────────
if (typeof process !== "undefined" && process.argv[1] === import.meta.url) {
  connect().then(() => {
    console.log("{{DEVICE_NAME}} Controller running. Press Ctrl+C to exit.");
    // Push defaults to hardware on connect
    for (const p of PARAMS) setParam(p.paramId, p.default ?? p.minVal);
  });
}
