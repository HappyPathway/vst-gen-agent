#include "DeviceEditor.h"
#include <BinaryData.h>

{{CLASS_NAME}}Editor::{{CLASS_NAME}}Editor({{CLASS_NAME}}Processor& p,
                                           juce::AudioProcessorValueTreeState& state)
    : AudioProcessorEditor(&p), processorRef(p), apvts(state)
{
    // Load panel backdrop from compiled binary data
    panelImage = juce::ImageCache::getFromMemory(
        BinaryData::panel_png, BinaryData::panel_pngSize);

    // Status bar
    statusLabel.setJustificationType(juce::Justification::centredLeft);
    statusLabel.setFont(juce::Font(juce::FontOptions(12.f)));
    statusLabel.setColour(juce::Label::textColourId, juce::Colours::lightgreen);
    statusLabel.setText("{{DEVICE_NAME}} — searching for device…", juce::dontSendNotification);
    addAndMakeVisible(statusLabel);

    // Create knobs from kKnobs table
    for (auto& def : kKnobs)
        addKnob(def);

    setSize(kEditorW, kEditorH);
}

{{CLASS_NAME}}Editor::~{{CLASS_NAME}}Editor() {}

PanelKnob* {{CLASS_NAME}}Editor::addKnob(const KnobDef& def)
{
    auto* k = knobs.add(new PanelKnob());
    k->slider.setRotaryParameters(juce::MathConstants<float>::pi * 1.25f,
                                  juce::MathConstants<float>::pi * 2.75f, true);
    addAndMakeVisible(k->slider);
    layoutKnob(k, def);

    k->label.setText(def.label, juce::dontSendNotification);
    k->label.setFont(juce::Font(juce::FontOptions(9.f)));
    k->label.setColour(juce::Label::textColourId, juce::Colours::white.withAlpha(0.85f));
    k->label.setJustificationType(juce::Justification::centred);
    addAndMakeVisible(k->label);

    k->attachment = std::make_unique<juce::AudioProcessorValueTreeState::SliderAttachment>(
        apvts, def.paramId, k->slider);

    // Store position for paint-time use
    k->slider.getProperties().set("cx",   def.cx);
    k->slider.getProperties().set("cy",   def.cy);
    k->slider.getProperties().set("diam", def.diam);

    return k;
}

void {{CLASS_NAME}}Editor::layoutKnob(PanelKnob* k, const KnobDef& def)
{
    int diam = def.diam;
    int x = def.cx - diam / 2;
    int y = def.cy - diam / 2 + kStatusH;
    k->slider.setBounds(x, y, diam, diam);
    k->label.setBounds(x - 4, y + diam + 1, diam + 8, 12);
}

void {{CLASS_NAME}}Editor::paint(juce::Graphics& g)
{
    g.fillAll(juce::Colour(0xff1a1a1a));

    // Draw panel backdrop starting below status bar
    if (panelImage.isValid())
        g.drawImage(panelImage, 0, kStatusH, kEditorW, kEditorH - kStatusH,
                    0, 0, panelImage.getWidth(), panelImage.getHeight());
}

void {{CLASS_NAME}}Editor::resized()
{
    statusLabel.setBounds(8, 0, kEditorW - 16, kStatusH);
}
