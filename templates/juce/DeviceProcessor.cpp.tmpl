void {{CLASS_NAME}}Processor::sendNrpn(int channel, int msb, int lsb, int value)
{
    if (!midiOut) return;
    int ch = juce::jlimit(0, 15, channel - 1);
    midiOut->sendMessageNow(juce::MidiMessage::controllerEvent(ch + 1, 99, msb));
    midiOut->sendMessageNow(juce::MidiMessage::controllerEvent(ch + 1, 98, lsb));
    midiOut->sendMessageNow(juce::MidiMessage::controllerEvent(ch + 1,  6, (value >> 7) & 0x7F));
    midiOut->sendMessageNow(juce::MidiMessage::controllerEvent(ch + 1, 38,  value       & 0x7F));
}

