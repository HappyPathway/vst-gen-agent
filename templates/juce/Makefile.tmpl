# {{DEVICE_NAME}} Controller — build & install
# Generated by vst-gen-agent
#
# Usage:
#   make              # configure (if needed) + build Debug
#   make release      # build Release
#   make install      # build + install VST3 + AU + Standalone
#   make run          # build + launch Standalone

BUILD_DIR   := build
BUILD_TYPE  ?= Debug
PLUGIN_NAME := {{DEVICE_NAME}} Controller
ARTIFACTS   := $(BUILD_DIR)/{{CLASS_NAME}}Plugin_artefacts/$(BUILD_TYPE)

VST3_DEST       := $(HOME)/Library/Audio/Plug-Ins/VST3
AU_DEST         := $(HOME)/Library/Audio/Plug-Ins/Components
STANDALONE_DEST := $(HOME)/Applications

VST3_BUNDLE       := $(PLUGIN_NAME).vst3
AU_BUNDLE         := $(PLUGIN_NAME).component
STANDALONE_BUNDLE := $(PLUGIN_NAME).app

# macOS 26+ SDK path for C++ stdlib headers (required on macOS 15+)
SDK := /Library/Developer/CommandLineTools/SDKs/MacOSX26.4.sdk
ifneq ($(wildcard $(SDK)/usr/include/c++/v1),)
    export CPLUS_INCLUDE_PATH := $(SDK)/usr/include/c++/v1
endif

CMAKE_FLAGS := -G Ninja -DCMAKE_BUILD_TYPE=$(BUILD_TYPE)

.PHONY: all release install install-release run configure clean

all: $(BUILD_DIR)/build.ninja
	cmake --build $(BUILD_DIR) --parallel

release:
	$(MAKE) BUILD_TYPE=Release all

$(BUILD_DIR)/build.ninja:
	cmake -B $(BUILD_DIR) $(CMAKE_FLAGS)

configure:
	cmake -B $(BUILD_DIR) $(CMAKE_FLAGS)

install: all
	@echo "Installing VST3..."
	@mkdir -p "$(VST3_DEST)"
	@rm -rf "$(VST3_DEST)/$(VST3_BUNDLE)"
	cp -R "$(ARTIFACTS)/VST3/$(VST3_BUNDLE)" "$(VST3_DEST)/"
	@echo "Installing AU..."
	@mkdir -p "$(AU_DEST)"
	@rm -rf "$(AU_DEST)/$(AU_BUNDLE)"
	cp -R "$(ARTIFACTS)/AU/$(AU_BUNDLE)" "$(AU_DEST)/"
	@echo "Installing Standalone..."
	@mkdir -p "$(STANDALONE_DEST)"
	@rm -rf "$(STANDALONE_DEST)/$(STANDALONE_BUNDLE)"
	cp -R "$(ARTIFACTS)/Standalone/$(STANDALONE_BUNDLE)" "$(STANDALONE_DEST)/"
	@echo "Done. Run: open '$(STANDALONE_DEST)/$(STANDALONE_BUNDLE)'"

run: all
	open "$(ARTIFACTS)/Standalone/$(STANDALONE_BUNDLE)"

clean:
	rm -rf $(BUILD_DIR)
